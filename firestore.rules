rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each user's remembered facts live in memory/{uid}. Only that
    // signed-in user (including guest/anonymous sessions, which get
    // their own uid) can read or write their own document.
    match /memory/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
